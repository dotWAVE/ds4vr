{
    "jsonid": "input_profile",
    "controller_type": "oculus_touch",
    "legacy_binding": "{ds4vr}/input/legacy_bindings_oculus_touch.json",
    "input_bindingui_mode": "controller_handed",
    "input_bindingui_left": {
        "image": "{ds4vr}/icons/oculus_touch_left.svg"
    },
    "input_bindingui_right": {
        "image": "{ds4vr}/icons/oculus_touch_right.svg"
    },
    "device_class": "TrackedDeviceClass_Controller",
    "resource_root": "ds4vr",
    "should_show_binding_errors": true,
    "input_source": {
        "/input/system": {
            "type": "button",
            "click": true,
            "binding_image_point": [0, 0],
            "order": 1
        },
        "/input/trigger": {
            "type": "trigger",
            "click": true,
            "touch": true,
            "value": true,
            "binding_image_point": [0, 0],
            "order": 2
        },
        "/input/grip": {
            "type": "trigger",
            "click": true,
            "value": true,
            "binding_image_point": [0, 0],
            "order": 3
        },
        "/input/joystick": {
            "type": "joystick",
            "click": true,
            "touch": true,
            "binding_image_point": [0, 0],
            "order": 4
        },
        "/input/x": {
            "type": "button",
            "click": true,
            "touch": true,
            "side": "left",
            "binding_image_point": [0, 0],
            "order": 5
        },
        "/input/y": {
            "type": "button",
            "click": true,
            "touch": true,
            "side": "left",
            "binding_image_point": [0, 0],
            "order": 6
        },
        "/input/a": {
            "type": "button",
            "click": true,
            "touch": true,
            "side": "right",
            "binding_image_point": [0, 0],
            "order": 5
        },
        "/input/b": {
            "type": "button",
            "click": true,
            "touch": true,
            "side": "right",
            "binding_image_point": [0, 0],
            "order": 6
        },
        "/input/thumbrest": {
            "type": "button",
            "touch": true,
            "binding_image_point": [0, 0],
            "order": 7
        },
        "/pose/raw": {
            "type": "pose"
        },
        "/output/haptic": {
            "type": "haptic"
        }
    },
    "default_bindings": []
}
